name: Python package

on:
  push:
    branches: [ "main" ]
  pull_request:

permissions:
  contents: read

jobs:
  # -------------------------------------------------------------------
  # Lint & Format
  # -------------------------------------------------------------------
  lint:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v5
    - uses: actions/setup-python@v6
      with:
        python-version: "3.12"
    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        python -m pip install -e ".[lint]"
    - name: Check formatting with ruff
      run: ruff format --check .
    - name: Lint with ruff
      run: ruff check .

  # -------------------------------------------------------------------
  # Unit tests + Coverage (multi-version matrix)
  # -------------------------------------------------------------------
  test:
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        python-version: ["3.10", "3.11", "3.12", "3.13"]
    steps:
    - uses: actions/checkout@v5
    - name: Set up Python ${{ matrix.python-version }}
      uses: actions/setup-python@v6
      with:
        python-version: ${{ matrix.python-version }}
    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        python -m pip install -e ".[dev,lint]"
    - name: Run tests with coverage
      run: |
        pytest --cov=pywrkr --cov-report=xml --cov-report=term-missing --cov-fail-under=85
    - name: Upload coverage artifact
      if: matrix.python-version == '3.12'
      uses: actions/upload-artifact@v4
      with:
        name: coverage-report
        path: coverage.xml

  # -------------------------------------------------------------------
  # Type checking with mypy
  # -------------------------------------------------------------------
  typecheck:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v5
    - uses: actions/setup-python@v6
      with:
        python-version: "3.12"
    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        python -m pip install -e ".[dev,lint]"
    - name: Run mypy
      run: python -m mypy src/pywrkr/ --ignore-missing-imports

  # -------------------------------------------------------------------
  # Security scanning
  # -------------------------------------------------------------------
  security:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v5
    - uses: actions/setup-python@v6
      with:
        python-version: "3.12"
    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        python -m pip install -e ".[security]"
    - name: Run bandit (security linter)
      run: python -m bandit -r src/pywrkr/ -c pyproject.toml
    - name: Run pip-audit (dependency vulnerabilities)
      run: python -m pip_audit
